/* AgentNexus TUI — OpenCode Warm Theme */

/* ===== Palette ===== */
$bg: #1a1b20;
$surface: #22242b;
$elevated: #292b33;
$text: #e2e3e7;
$text-dim: #848893;
$muted: #5d606b;
$primary: #fab283;
$secondary: #6ba5f2;
$accent: #a78bfa;
$success: #7fd88f;
$error: #e06c75;
$warning: #f5a742;
$assistant: #6ba5f2;
$user: #a78bfa;
$tool: #f5a742;
$border: #333640;

/* ===== Base ===== */
Screen { background: $bg; color: $text; }

/* ===== Top Bar ===== */
#top-bar {
  height: 1;
  padding: 0 1;
  background: $surface;
  border-bottom: solid $primary;
  color: $text-dim;
}

/* ===== Main Layout ===== */
#main-area { height: 1fr; }
#chat-area { width: 1fr; overflow-y: auto; }

/* ===== Messages ===== */
ChatMessage {
  padding: 1 1 1 2;
  height: auto;
  overflow-y: auto;
}
ChatMessage.assistant { border-left: solid $assistant; }
ChatMessage.user      { border-left: solid $user; }
ChatMessage.system    { border-left: solid $muted; }

#msg-role { text-style: bold; }
#msg-role.assistant { color: $assistant; }
#msg-role.user      { color: $user; }
#msg-role.system    { color: $text-dim; }

#msg-content { color: $text; width: 1fr; }

/* ===== Tool Call ===== */
ToolCall {
  padding: 0 1;
  margin: 0 0 0 2;
  border-left: solid $tool;
  height: auto;
  background: $surface;
}
ToolCall #tool-name   { color: $tool; text-style: bold; }
ToolCall #tool-result { color: $text-dim; width: 1fr; }
ToolCall #tool-meta   { color: $muted; text-style: italic; }

/* ===== Input Area ===== */
#input-area {
  height: auto;
  padding: 0 1;
  background: $surface;
  border-top: solid $border;
}
#input-prompt { width: 1; color: $primary; text-style: bold; }
#chat-input   { width: 1fr; padding: 0 1; }
#chat-input:focus { border: solid $primary; }

/* ===== Side Panel ===== */
#side-panel {
  width: 28;
  padding: 1;
  background: $surface;
  border-left: solid $border;
  overflow-y: auto;
}
#side-panel .card {
  padding: 1;
  margin: 0 0 1 0;
  background: $elevated;
  border: solid $border;
}
#side-panel .card-title {
  color: $primary;
  text-style: bold;
  padding: 0 0 1 0;
  margin: 0 0 1 0;
  border-bottom: solid $border;
}
#side-panel .card-text { color: $text-dim; }
#side-panel .card-dim  { color: $muted; text-style: italic; }

/* ===== HUD ===== */
#hud { height: 1; background: $surface; }
#hud-text { width: 100%; color: $text-dim; }

/* ===== Scrollbar ===== */
Scrollbar { background: transparent; color: $border; }
Scrollbar:hover { color: $text-dim; }

/* ===== Loading ===== */
LoadingIndicator { color: $primary; }
