/* ===== Palette ===== */
$bg: #1a1b20;
$surface: #22242b;
$elevated: #292b33;
$text: #e2e3e7;
$text-dim: #848893;
$muted: #5d606b;
$primary: #fab283;
$secondary: #6ba5f2;
$accent: #a78bfa;
$success: #7fd88f;
$error: #e06c75;
$warning: #f5a742;
$assistant: #6ba5f2;
$user: #a78bfa;
$tool: #f5a742;
$border: #333640;

/* ===== Base ===== */
Screen { background: $bg; color: $text; }

/* ===== Scrollbar ===== */
Scrollbar { background: transparent; color: $border; }
Scrollbar:hover { color: $text-dim; }

/* ===== Loading ===== */
LoadingIndicator { color: $primary; }

/* For any widget without custom background */
Widget { background: transparent; }
