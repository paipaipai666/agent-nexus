/* Palette — sync with base.tcss if changing values */
$bg: #1a1b20;
$surface: #22242b;
$elevated: #292b33;
$text: #e2e3e7;
$text-dim: #848893;
$muted: #5d606b;
$primary: #fab283;
$secondary: #6ba5f2;
$accent: #a78bfa;
$success: #7fd88f;
$error: #e06c75;
$warning: #f5a742;
$assistant: #6ba5f2;
$user: #a78bfa;
$tool: #f5a742;
$border: #333640;

/* ===== Main Layout =====
   Screen uses vertical layout.
   Children: top-bar(1) → middle(1fr) → hud(1) → input-area(3)
*/
Screen {
    layout: vertical;
}
#top-bar {
    height: 1;
}
#middle {
    height: 1fr;
    layout: horizontal;
}
#chat-area {
    width: 1fr;
    height: 100%;
    overflow-y: auto;
}
#side-panel {
    width: 28;
    height: 100%;
}
#hud {
    height: 1;
}
#input-area {
    height: auto;
    min-height: 3;
}
