/* Palette — sync with base.tcss if changing values */
$bg: #1a1b20;
$surface: #22242b;
$elevated: #292b33;
$text: #e2e3e7;
$text-dim: #848893;
$muted: #5d606b;
$primary: #fab283;
$secondary: #6ba5f2;
$accent: #a78bfa;
$success: #7fd88f;
$error: #e06c75;
$warning: #f5a742;
$assistant: #6ba5f2;
$user: #a78bfa;
$tool: #f5a742;
$border: #333640;

/* ===== Input Area ===== */
#input-area {
  height: auto;
  min-height: 3;
  padding: 0 1;
  background: $surface;
  border-top: solid $border;
  border-bottom: solid $border;
}
#input-row {
  height: auto;
  padding: 1 0;
}
#input-prompt { width: 1; color: $primary; text-style: bold; }
#chat-input {
  width: 1fr;
  padding: 0 1;
  border: round $border;
}
#chat-input:focus {
  border: round $primary;
}
