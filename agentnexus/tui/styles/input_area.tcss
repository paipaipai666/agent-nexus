/* Palette — sync with base.tcss if changing values */
$surface: #191c21;
$elevated: #20242b;
$text: #d9dde5;
$text-dim: #8c93a1;
$primary: #d59f5f;
$secondary: #70a6e8;
$border: #2b3038;

/* ===== Input Area ===== */
#input-area {
  height: 3;
  padding: 0 1;
  background: $surface;
  border-top: tall $border;
  border-bottom: tall $border;
}

#input-row {
  height: 1;
  padding: 0;
  content-align: center middle;
}

#input-prompt {
  width: 2;
  height: 1;
  color: $secondary;
  text-style: bold;
  content-align: center middle;
}

#chat-input {
  width: 1fr;
  height: 1;
  padding: 0 1;
  border: none;
  background: transparent;
  color: $text;
}

#chat-input:focus {
  color: $text;
}
