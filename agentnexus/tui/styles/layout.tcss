/* Palette — sync with base.tcss if changing values */
$bg: #14161a;
$surface: #191c21;
$sidepanel: #171a1f;
$border: #2b3038;

/* ===== Main Layout ===== */
Screen {
    layout: vertical;
}

#top-bar {
    height: 1;
}

#middle {
    height: 1fr;
    layout: horizontal;
    background: $bg;
}

#chat-area {
    width: 1fr;
    height: 100%;
    padding: 1 2 0 2;
    overflow-y: auto;
    scrollbar-size-vertical: 1;
}

#side-panel {
    width: 38;
    min-width: 34;
    height: 100%;
    scrollbar-size-vertical: 1;
}

#hud {
    height: 1;
}

#command-palette {
    display: none;
    height: 12;
    padding: 1 2;
    background: $surface;
    border-top: tall $border;
    color: $text;
    overflow-y: auto;
    scrollbar-size-vertical: 1;
}

#command-palette-content {
    width: 100%;
    height: auto;
}

#input-area {
    height: 3;
}
