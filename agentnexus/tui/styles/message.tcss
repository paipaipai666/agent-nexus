/* Palette — sync with base.tcss if changing values */
$bg: #14161a;
$surface: #191c21;
$elevated: #20242b;
$text: #d9dde5;
$text-dim: #8c93a1;
$muted: #606774;
$primary: #d59f5f;
$secondary: #70a6e8;
$accent: #9d8fe8;
$success: #75c990;
$error: #e06c75;
$warning: #d6a25d;
$assistant: #70a6e8;
$user: #9d8fe8;
$tool: #d6a25d;
$border: #2b3038;

/* ===== Messages ===== */
ChatMessage {
  padding: 0 1;
  height: auto;
  overflow-y: auto;
  margin-bottom: 1;
  border-left: tall $border;
}

ChatMessage.assistant {
  border-left: tall $assistant;
}

ChatMessage.user {
  border-left: tall $user;
}

ChatMessage.system {
  color: $text-dim;
  border-left: tall $muted;
}

#msg-content {
  color: $text;
  width: 1fr;
}

.msg-text {
  color: $text;
  width: 1fr;
}

.msg-code {
  background: $elevated;
  margin: 1 0;
  padding: 1;
  color: $text;
  width: 1fr;
  border-left: tall $muted;
}

/* ===== Tool Call ===== */
ToolCall {
  padding: 0 1;
  margin-bottom: 1;
  border-left: tall $tool;
  height: auto;
  background: $surface;
}

ToolCall #tool-name {
  color: $tool;
  text-style: bold;
}

ToolCall #tool-result {
  color: $text-dim;
  width: 1fr;
}

ToolCall #tool-meta {
  color: $muted;
  text-style: italic;
}
