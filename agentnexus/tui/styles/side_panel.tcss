/* Palette — sync with base.tcss if changing values */
$sidepanel: #171a1f;
$surface: #191c21;
$elevated: #20242b;
$text: #d9dde5;
$text-dim: #8c93a1;
$muted: #606774;
$primary: #d59f5f;
$secondary: #70a6e8;
$border: #2b3038;

/* ===== Side Panel ===== */
#side-panel {
  width: 38;
  min-width: 34;
  padding: 1;
  background: $sidepanel;
  border-left: tall $border;
  overflow-y: auto;
}

#side-panel .panel-eyebrow {
  height: 1;
  color: $secondary;
  text-style: bold;
  margin-bottom: 1;
}

#side-panel .section-title {
  height: 1;
  color: $text;
  text-style: bold;
  margin: 1 0 0 0;
}

#side-panel .section-body {
  color: $text-dim;
  background: $surface;
  border-left: tall $border;
  padding: 0 1;
  margin: 0 0 1 0;
  height: auto;
}
